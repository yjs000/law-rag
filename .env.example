# 국가법령정보 공동활용 Open API
LAW_OPEN_API_OC=
LAW_OPEN_API_BASE_URL=https://www.law.go.kr/DRF
COLLECTOR_STATE_DIR=.collector-state
COLLECTOR_REQUEST_TIMEOUT_SECONDS=30

# Supabase / PostgreSQL (서버 전용)
APP_NAME=에너지 법령 RAG
ENVIRONMENT=development
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_RAW_BUCKET=law-raw

# 생성 공급자: NVIDIA hosted NIM 또는 기존 OpenAI.
ANSWER_PROVIDER=nvidia_nim
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_ANSWER_MODEL=nvidia/nemotron-3-ultra-550b-a55b
ANSWER_MAX_OUTPUT_TOKENS=4096
ANSWER_TIMEOUT_SECONDS=30

# OpenAI 생성 또는 임베딩. NVIDIA 생성과 임베딩 키는 서로 독립적입니다.
OPENAI_API_KEY=
AI_MODE=auto
OPENAI_ANSWER_MODEL=gpt-5.6-terra
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=512

# 익명 사용량 HMAC. 충분히 긴 무작위 문자열을 사용하세요.
RATE_LIMIT_SECRET=development-only-secret
AI_DAILY_LIMIT=3
SEARCH_DAILY_LIMIT=30

# 배포 URL
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
REQUEST_TIMEOUT_SECONDS=30
