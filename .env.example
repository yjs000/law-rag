# 국가법령정보 공동활용 Open API
LAW_OPEN_API_OC=

# Supabase / PostgreSQL (서버 전용)
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RAW_BUCKET=law-raw

# OpenAI. 비어 있으면 검색 전용 모드로 동작합니다.
OPENAI_API_KEY=
AI_MODE=auto
OPENAI_ANSWER_MODEL=gpt-5.6-terra
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# 익명 사용량 HMAC. 충분히 긴 무작위 문자열을 사용하세요.
RATE_LIMIT_SECRET=change-me-in-production

# 배포 URL
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
