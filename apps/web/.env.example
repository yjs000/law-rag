# Local browser -> local FastAPI. This value is public and must never be a secret.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public browser credentials from Supabase Project Settings > API Keys.
# Never put SUPABASE_SECRET_KEY or a Google client secret in apps/web.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
