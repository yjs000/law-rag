# Local: copy to .env.local. Vercel: register in Project Settings instead.
APP_NAME=에너지 법령 RAG
ENVIRONMENT=development

# Supabase PostgreSQL via Supavisor.
# Vercel runtime: Supavisor transaction mode (port 6543).
DATABASE_URL=
# Alembic migrations: Supavisor session mode (port 5432) on IPv4-only hosts.
DIRECT_URL=

# Server-side Supabase Auth/Storage access. SUPABASE_SECRET_KEY must start with
# sb_secret_ and must never be exposed through NEXT_PUBLIC_* or browser code.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_RAW_BUCKET=law-raw

# Local mock fallback only. Do not configure this on Vercel production.
COLLECTOR_STATE_DIR=.collector-state

# Answer generation. NVIDIA_API_KEY is server-only and must be registered in Vercel.
ANSWER_PROVIDER=nvidia_nim
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_ANSWER_MODEL=nvidia/nemotron-3-ultra-550b-a55b
ANSWER_MAX_OUTPUT_TOKENS=4096
ANSWER_TIMEOUT_SECONDS=30

# OpenAI generation/embedding. NVIDIA generation does not require this key,
# but semantic vector search still needs an embedding provider and indexed vectors.
OPENAI_API_KEY=
AI_MODE=auto
OPENAI_ANSWER_MODEL=gpt-5.6-terra
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=512

# HMAC key for privacy-preserving anonymous rate-limit identifiers.
# Replace this with a different random value in Preview and Production.
RATE_LIMIT_SECRET=development-only-secret
AI_DAILY_LIMIT=3
SEARCH_DAILY_LIMIT=30
AUTHENTICATED_AI_DAILY_LIMIT=10
AUTHENTICATED_SEARCH_DAILY_LIMIT=100

# Exact web origin only; never use a *.vercel.app wildcard.
WEB_ORIGIN=http://localhost:3000
REQUEST_TIMEOUT_SECONDS=30
